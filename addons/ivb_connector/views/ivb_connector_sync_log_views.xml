<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ivb_connector_sync_log_tree" model="ir.ui.view">
        <field name="name">ivb.connector.sync.log.tree</field>
        <field name="model">ivb.connector.sync.log</field>
        <field name="arch" type="xml">
            <tree decoration-danger="status == 'error'" decoration-success="status == 'success'" create="false" edit="false">
                <field name="create_date" string="Fecha"/>
                <field name="platform"/>
                <field name="operation"/>
                <field name="status"/>
                <field name="record_count"/>
                <field name="duration_seconds"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="action_ivb_connector_sync_log" model="ir.actions.act_window">
        <field name="name">Historial de sincronización</field>
        <field name="res_model">ivb.connector.sync.log</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
