<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ivb_connector" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ivb.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="IVB Connector" string="IVB Connector" name="ivb_connector">
                    <block title="Plataforma" name="ivb_connector_platform_setting_container">
                        <setting id="ivb_connector_platform_setting" help="WooCommerce está implementado. Shopify queda como placeholder hasta que termine la migración de la tienda del cliente.">
                            <field name="ivb_connector_platform"/>
                        </setting>
                    </block>
                    <block title="Credenciales" name="ivb_connector_credentials_setting_container">
                        <setting id="ivb_connector_store_url_setting">
                            <label for="ivb_connector_store_url" string="URL de la tienda"/>
                            <field name="ivb_connector_store_url" placeholder="https://profesional.ivbwellness.com"/>
                        </setting>
                        <setting id="ivb_connector_api_key_setting">
                            <label for="ivb_connector_api_key" string="API Key / Consumer Key"/>
                            <field name="ivb_connector_api_key"/>
                        </setting>
                        <setting id="ivb_connector_api_secret_setting">
                            <label for="ivb_connector_api_secret" string="API Secret / Consumer Secret"/>
                            <field name="ivb_connector_api_secret" password="True"/>
                        </setting>
                    </block>
                    <block title="Qué sincronizar" name="ivb_connector_flags_setting_container">
                        <setting id="ivb_connector_sync_products_setting">
                            <field name="ivb_connector_sync_products"/>
                            <label for="ivb_connector_sync_products"/>
                        </setting>
                        <setting id="ivb_connector_sync_customers_setting">
                            <field name="ivb_connector_sync_customers"/>
                            <label for="ivb_connector_sync_customers"/>
                        </setting>
                        <setting id="ivb_connector_sync_orders_setting">
                            <field name="ivb_connector_sync_orders"/>
                            <label for="ivb_connector_sync_orders"/>
                        </setting>
                        <setting id="ivb_connector_push_stock_setting">
                            <field name="ivb_connector_push_stock"/>
                            <label for="ivb_connector_push_stock"/>
                        </setting>
                    </block>
                    <block title="Acciones" name="ivb_connector_actions_setting_container">
                        <setting id="ivb_connector_actions_setting">
                            <button name="action_ivb_connector_test_connection" type="object"
                                    string="Probar conexión" class="btn btn-secondary"/>
                            <button name="action_ivb_connector_sync_now" type="object"
                                    string="Sincronizar ahora" class="btn btn-primary ms-2"/>
                            <div class="text-muted mt-2">
                                Última sincronización: <field name="ivb_connector_last_sync" readonly="1" class="oe_inline"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
