<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_ivb_connector" model="ir.ui.view">
        <field name="name">res.partner.form.ivb.connector</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="IVB - Condiciones" name="ivb_connector_conditions">
                    <group>
                        <group string="SEPA">
                            <field name="ivb_sepa_days"/>
                            <field name="ivb_sepa_min_amount"/>
                            <field name="ivb_sepa_max_amount"/>
                        </group>
                        <group string="Límite de compra">
                            <field name="ivb_purchase_limit_enabled"/>
                            <field name="ivb_monthly_purchase_limit" invisible="not ivb_purchase_limit_enabled"/>
                        </group>
                    </group>
                    <group>
                        <group string="Seguimiento comercial">
                            <field name="ivb_apertura_email"/>
                            <field name="ivb_procedencia"/>
                            <field name="ivb_iqvia"/>
                            <field name="ivb_visitada"/>
                            <field name="ivb_fecha_cumpleanos"/>
                        </group>
                        <group string="Escala">
                            <field name="ivb_escala"/>
                            <field name="ivb_escala_automatica"/>
                            <field name="ivb_unidades_compradas"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
